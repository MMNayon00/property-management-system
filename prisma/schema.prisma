generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String     @id @default(cuid())
  email            String?    @unique
  phone            String?    @unique
  password         String?
  firstName        String
  lastName         String?
  profileImage     String?
  role             UserRole   @default(OWNER)
  status           UserStatus @default(APPROVED)
  approvedAt       DateTime?
  approvedBy       String?
  rejectionReason  String?
  refreshToken     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  lastLoginAt      DateTime?
  otp              String?
  otpExpires       DateTime?
  ownerId          String?
  owner            User?      @relation("OwnerManager", fields: [ownerId], references: [id], onDelete: SetNull)
  managers         User[]     @relation("OwnerManager")
  buildings        Building[]
  payments         Payment[]  @relation("CreatedBy")
  tenant           Tenant?    @relation("UserTenant")

  @@index([email])
  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@index([ownerId])
}

model Building {
  id          String       @id @default(cuid())
  name        String
  address     String
  area        String?
  totalFlats  Int          @default(0)
  ownerId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  flats       Flat[]
  payments    Payment[]
  rentRecords RentRecord[]

  @@index([ownerId])
  @@index([createdAt])
}

model Flat {
  id              String          @id @default(cuid())
  flatNumber      String
  floor           Int?
  baseRent        Int
  extraCharges    Int             @default(0)
  serviceCharges  Int             @default(0)
  status          FlatStatus      @default(VACANT)
  buildingId      String
  currentTenantId String?         @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  building        Building        @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  currentTenant   Tenant?         @relation("CurrentTenant", fields: [currentTenantId], references: [id])
  payments        Payment[]
  rentRecords     RentRecord[]
  tenantHistory   TenantHistory[]

  @@unique([buildingId, flatNumber])
  @@index([buildingId])
  @@index([currentTenantId])
  @@index([status])
}

model Tenant {
  id            String          @id @default(cuid())
  name          String
  email         String?
  phone         String?
  whatsapp      String?
  nidNumber     String?
  nidImage      String?
  profileImage  String?
  moveInDate    DateTime?
  moveOutDate   DateTime?
  currentFlatId String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  currentFlat   Flat?           @relation("CurrentTenant")
  history       TenantHistory[]
  rentRecords   RentRecord[]
  userId        String?         @unique
  advanceAmount Int             @default(0)
  advanceDate   DateTime?
  advanceReceived Boolean       @default(false)
  user          User?           @relation("UserTenant", fields: [userId], references: [id], onDelete: SetNull)

  @@index([nidNumber])
  @@index([currentFlatId])
  @@index([email])
}

model TenantHistory {
  id          String    @id @default(cuid())
  tenantId    String
  flatId      String
  moveInDate  DateTime
  moveOutDate DateTime?
  rentAmount  Int
  createdAt   DateTime  @default(now())
  flat        Flat      @relation(fields: [flatId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([flatId])
  @@index([moveInDate])
}

model RentRecord {
  id             String        @id @default(cuid())
  flatId         String
  tenantId       String?
  buildingId     String
  month          String        // format: "YYYY-MM"
  baseRent       Int
  extraCharges   Int           @default(0)
  serviceCharges Int           @default(0)
  totalAmount    Int           @default(0)
  paidAmount     Int           @default(0)
  dueAmount      Int           @default(0)
  paymentStatus  PaymentStatus @default(UNPAID)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  payments       Payment[]
  building       Building      @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  flat           Flat          @relation(fields: [flatId], references: [id], onDelete: Cascade)
  tenant         Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([flatId, month])
  @@unique([tenantId, month])
  @@index([flatId])
  @@index([tenantId])
  @@index([buildingId])
  @@index([month])
  @@index([paymentStatus])
}

model Payment {
  id           String     @id @default(cuid())
  rentRecordId String
  flatId       String
  buildingId   String
  amount       Int
  method       String?
  reference    String?
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  building     Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdBy    User       @relation("CreatedBy", fields: [createdById], references: [id])
  flat         Flat       @relation(fields: [flatId], references: [id], onDelete: Cascade)
  rentRecord   RentRecord @relation(fields: [rentRecordId], references: [id], onDelete: Cascade)

  @@index([rentRecordId])
  @@index([flatId])
  @@index([buildingId])
  @@index([createdById])
}

model Charge {
  id          String   @id @default(cuid())
  name        String
  description String?
  buildingId  String?
  amount      Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([buildingId])
  @@index([isActive])
}

enum UserRole {
  ADMIN
  OWNER
  MANAGER
  TENANT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum FlatStatus {
  VACANT
  OCCUPIED
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}
